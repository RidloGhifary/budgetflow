# App configuration
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/budgetflow
DB_WAIT_TIMEOUT_MS=60000
DB_WAIT_INTERVAL_MS=1000

# AI provider configuration
AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=15000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10
AI_DAILY_LIMIT_PER_USER=50

# Authentication and security settings
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10

# Email settings
BLOCKED_EMAIL_DOMAINS=
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_MS=5000
JOB_LOCK_TIMEOUT_MS=900000

# Export and import settings
EXPORT_STORAGE_DIR=storage/exports
EXPORT_EXPIRATION_DAYS=7
EXPORT_MAX_RANGE_DAYS=366
EXPORT_MAX_PENDING_PER_USER=3
IMPORT_STORAGE_DIR=storage/imports
IMPORT_MAX_FILE_SIZE_BYTES=5242880
IMPORT_MAX_ROWS=5000
IMPORT_BATCH_SIZE=100
IMPORT_MAX_PENDING_PER_USER=3
